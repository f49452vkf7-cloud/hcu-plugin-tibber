{
  "schemaVersion": "1.0",
  "id": "com.github.custom.hcu-tibber",
  "name": "Tibber Integration",
  "version": "1.1.10",
  "description": "Offizielles HCU-Plugin fuer Tibber-Preise und Zaehlerdaten via Intervall-Polling.",
  "author": "",
  "entrypoint": "node src/index.js",
  "permissions": {
    "network": {
      "outbound": [
        "://tibber.com"
      ]
    }
  },
  "exposedDevices": [
    {
      "id": "tibber_monitor_device",
      "name": "Tibber Monitor",
      "type": "GENERIC",
      "channels": [
        {
          "id": "values",
          "label": "Stromdaten",
          "type": "CUSTOM",
          "parameters": [
            {
              "id": "current_price",
              "type": "FLOAT",
              "unit": "EUR",
              "defaultValue": 0.0,
              "operations": ["READ", "EVENT"]
            },
            {
              "id": "pulse_consumption_today",
              "type": "FLOAT",
              "unit": "kWh",
              "defaultValue": 0.0,
              "operations": ["READ", "EVENT"]
            }
          ]
        }
      ]
    }
  ]
}