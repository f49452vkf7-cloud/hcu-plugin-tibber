{
  "schemaVersion": "1.0",
  "id": "custom.tibber.monitor",
  "name": "Tibber Integration",
  "version": "1.10.3",
  "description": "Natives HCU-Plugin fuer Tibber-Preise und Zaehlerdaten.",
  "author": "GitHub Community",
  "entrypoint": "node src/index.js",
  "permissions": {
    "network": {
      "outbound": [
        "://tibber.com"
      ]
    }
  },
  "exposedDevices": [
    {
      "id": "tibber_monitor_device",
      "name": "Tibber Monitor",
      "type": "GENERIC",
      "channels": [
        {
          "id": "values",
          "label": "Stromdaten",
          "type": "GENERIC_INPUT_CHANNEL",
          "parameters": [
            {
              "id": "VALUE",
              "type": "FLOAT",
              "unit": "EUR",
              "defaultValue": 0.0,
              "operations": ["READ", "EVENT"]
            },
            {
              "id": "ENERGY_COUNTER",
              "type": "FLOAT",
              "unit": "kWh",
              "defaultValue": 0.0,
              "operations": ["READ", "EVENT"]
            }
          ]
        }
      ]
    }
  ]
}
