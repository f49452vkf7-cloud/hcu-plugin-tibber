{
  "manifestVersion": 1,
  "id": "custom.tibber.monitor",
  "name": "Tibber Integration",
  "version": "1.13.1",
  "description": "Natives HCU-Plugin fuer Tibber-Preise und Zaehlerdaten.",
  "author": "GitHub Community",
  "entrypoint": "node src/index.js",
  "permissions": {
    "network": {
      "outbound": [
        "://tibber.com"
      ]
    }
  },
  "exposedDevices": [
    {
      "id": "tibber_price_device",
      "name": "Tibber Strompreis",
      "type": "VIRTUAL_DIMMER",
      "channels": [
        {
          "id": "vch0",
          "label": "Aktueller Preis",
          "type": "VIRTUAL_DIMMER_CHANNEL",
          "parameters": [
            {
              "id": "LEVEL",
              "type": "FLOAT",
              "defaultValue": 0.0,
              "operations": ["READ", "EVENT"]
            }
          ]
        }
      ]
    },
    {
      "id": "tibber_consumption_device",
      "name": "Tibber Verbrauch Heute",
      "type": "VIRTUAL_DIMMER",
      "channels": [
        {
          "id": "vch0",
          "label": "Tagesverbrauch",
          "type": "VIRTUAL_DIMMER_CHANNEL",
          "parameters": [
            {
              "id": "LEVEL",
              "type": "FLOAT",
              "defaultValue": 0.0,
              "operations": ["READ", "EVENT"]
            }
          ]
        }
      ]
    }
  ]
}
