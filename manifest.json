{
  "schemaVersion": "1.0",
  "id": "custom.tibber.monitor",
  "name": "Tibber Integration",
  "version": "1.9.4",
  "description": "Offizielles HCU-Plugin fuer Tibber-Preise und Dashboard-Zaehlerdaten.",
  "author": "GitHub Community",
  "entrypoint": "node src/index.js",
  "permissions": {
    "network": {
      "outbound": [
        "://tibber.com"
      ]
    }
  },
  "properties": [
    {
      "id": "tibber_current_price",
      "label": "Tibber Aktueller Strompreis",
      "type": "FLOAT",
      "unit": "EUR",
      "defaultValue": 0.0
    },
    {
      "id": "tibber_pulse_consumption_today",
      "label": "Tibber Pulse Stromverbrauch heute",
      "type": "FLOAT",
      "unit": "kWh",
      "defaultValue": 0.0
    }
  ]
}
